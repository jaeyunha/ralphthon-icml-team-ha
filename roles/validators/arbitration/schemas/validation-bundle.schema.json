{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/roles/validators/arbitration/validation-bundle.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_version", "submission_id", "frozen_at", "source_lanes", "findings", "conflicts", "content_hash"],
  "properties": {
    "bundle_version": {"const": 1},
    "submission_id": {"type": "string", "minLength": 1},
    "frozen_at": {"type": "string", "format": "date-time"},
    "source_lanes": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "findings": {"type": "array", "items": {"type": "object"}},
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "finding_ids", "statuses", "resolution"],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "finding_ids": {"type": "array", "items": {"type": "string"}, "minItems": 2, "uniqueItems": true},
          "statuses": {"type": "array", "items": {"type": "string"}, "minItems": 2, "uniqueItems": true},
          "resolution": {"const": "surfaced_not_averaged"}
        }
      }
    },
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
