{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/roles/reviewer/profiles/v2/initial-review.schema.json",
  "title": "CalibrationV2InitialReviewArtifact",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "reviewer_id", "phase", "task_id", "findings", "completed"],
      "properties": {
        "artifact_type": {"const": "review_task"},
        "reviewer_id": {"type": "string", "minLength": 1},
        "phase": {"const": "initial-review"},
        "task_id": {"type": "string", "minLength": 1},
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "anchors", "evidence_refs"],
            "properties": {
              "text": {"type": "string", "minLength": 1},
              "anchors": {"type": "array", "items": {"type": "string"}},
              "evidence_refs": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "completed": {"const": true}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "reviewer_id", "summary", "strengths", "weaknesses", "scores", "overall_judgment", "key_questions", "limitations", "confidence", "ethical_concerns", "evidence_refs"],
      "properties": {
        "version": {"const": 1},
        "reviewer_id": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "strengths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "anchors"],
            "properties": {
              "text": {"type": "string", "minLength": 1},
              "anchors": {"type": "array", "minItems": 1, "items": {"type": "string"}}
            }
          }
        },
        "weaknesses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text", "severity", "affected_claims", "anchors"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "text": {"type": "string", "minLength": 1},
              "severity": {"enum": ["minor", "major", "critical"]},
              "affected_claims": {"type": "array", "items": {"type": "string"}},
              "anchors": {"type": "array", "minItems": 1, "items": {"type": "string"}}
            }
          }
        },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": ["soundness", "presentation", "significance", "originality", "overall"],
          "properties": {
            "soundness": {"type": "integer", "minimum": 1, "maximum": 4},
            "presentation": {"type": "integer", "minimum": 1, "maximum": 4},
            "significance": {"type": "integer", "minimum": 1, "maximum": 4},
            "originality": {"type": "integer", "minimum": 1, "maximum": 4},
            "overall": {"type": "integer", "minimum": 1, "maximum": 6}
          }
        },
        "overall_judgment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["acceptance_case", "rejection_case", "dominant_case", "dominance_rationale", "significance_basis"],
          "properties": {
            "acceptance_case": {"$ref": "#/$defs/evidenceCase"},
            "rejection_case": {"$ref": "#/$defs/evidenceCase"},
            "dominant_case": {"enum": ["acceptance", "rejection"]},
            "dominance_rationale": {"type": "string", "minLength": 1},
            "significance_basis": {"$ref": "#/$defs/evidenceCase"}
          }
        },
        "key_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "question", "possible_score_impact"],
            "properties": {
              "id": {"type": "string"},
              "question": {"type": "string"},
              "possible_score_impact": {"type": "string"}
            }
          }
        },
        "limitations": {"type": "string"},
        "confidence": {"type": "integer", "minimum": 1, "maximum": 5},
        "ethical_concerns": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      }
    }
  ],
  "$defs": {
    "evidenceCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "anchors"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "anchors": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
