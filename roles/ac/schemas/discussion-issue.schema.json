{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/roles/ac/discussion-issue.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["issue_id", "topic", "trigger", "decisive", "status", "round", "question", "expected_respondents", "positions", "summary", "resolution", "evidence_refs"],
  "properties": {
    "issue_id": {"type": "string", "minLength": 1},
    "topic": {"type": "string", "minLength": 1},
    "trigger": {"type": "string", "minLength": 1},
    "decisive": {"type": "boolean"},
    "status": {"enum": ["open", "resolved", "irreducibly_disputed"]},
    "round": {"type": "integer", "minimum": 1, "maximum": 2},
    "question": {"type": "string", "minLength": 1},
    "expected_respondents": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "positions": {"type": "array", "items": {"type": "object"}},
    "summary": {"type": ["string", "null"]},
    "resolution": {"enum": [null, "resolved", "irreducibly_disputed"]},
    "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  }
}
