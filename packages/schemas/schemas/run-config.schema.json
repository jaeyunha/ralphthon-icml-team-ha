{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/run-config.schema.json",
  "title": "RunConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["config_version", "run_id", "mode", "review_start_time", "literature_cutoff", "submission_manifest_path", "reviewer_count"],
  "properties": {
    "config_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["historical_benchmark", "current_blind_submission", "live_submission", "batch_conference"]},
    "review_start_time": {"type": "string", "format": "date-time"},
    "literature_cutoff": {"type": "string", "minLength": 1},
    "submission_manifest_path": {"type": "string", "minLength": 1},
    "reviewer_count": {"type": "integer", "minimum": 3, "maximum": 6},
    "privacy_mode": {"enum": ["strict", "standard"]},
    "freeze_literature_snapshot": {"type": "boolean"},
    "block_openreview": {"type": "boolean"},
    "block_exact_target_title_search": {"type": "boolean"},
    "block_target_authors": {"type": "boolean"},
    "block_target_duplicates": {"type": "boolean"},
    "block_target_preprint": {"type": "boolean"},
    "block_private_track1_data": {"type": "boolean"},
    "block_human_reviews": {"type": "boolean"},
    "block_rebuttals": {"type": "boolean"},
    "block_meta_review": {"type": "boolean"},
    "block_decision": {"type": "boolean"},
    "block_camera_ready_version": {"type": "boolean"},
    "block_post_cutoff_sources": {"type": "boolean"},
    "max_wall_clock_hours": {"type": "number", "exclusiveMinimum": 0},
    "max_budget_usd": {"type": "number", "minimum": 0},
    "max_reviewer_restarts": {"type": "integer", "minimum": 0},
    "max_validator_restarts": {"type": "integer", "minimum": 0},
    "max_author_restarts": {"type": "integer", "minimum": 0},
    "max_ac_restarts": {"type": "integer", "minimum": 0},
    "max_discussion_rounds": {"type": "integer", "minimum": 1},
    "stable_score_rounds": {"type": "integer", "minimum": 1},
    "no_progress_threshold": {"type": "integer", "minimum": 1}
  }
}
