{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/benchmark-sterile-root-capability.schema.json",
  "title": "BenchmarkSterileRootCapability",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "principal", "role_root", "prompt_rpc_socket", "ever_rpc_socket", "read_only_mounts", "forbidden_roots", "network_enabled", "dns_enabled", "denied_capabilities", "contract_hash"],
  "properties": {
    "version": {"const": 1},
    "principal": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "kind", "campaign_id", "arm_id", "model_capable"],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["custodian", "matrix_coordinator", "model_role", "gold_annotator", "generated_annotator", "adjudicator", "scorer"]},
        "campaign_id": {"type": "string", "minLength": 1},
        "arm_id": {"type": ["string", "null"]},
        "model_capable": {"type": "boolean"}
      }
    },
    "role_root": {"type": "string", "pattern": "^/"},
    "prompt_rpc_socket": {"type": "string", "pattern": "^/"},
    "ever_rpc_socket": {"type": "string", "pattern": "^/"},
    "read_only_mounts": {"type": "array", "items": {"type": "string", "pattern": "^/"}},
    "forbidden_roots": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^/"}},
    "network_enabled": {"const": false},
    "dns_enabled": {"const": false},
    "denied_capabilities": {
      "type": "array", "uniqueItems": true,
      "items": {"enum": ["repository", "home", ".gjc", "outcome", "human_thread", "scorer", "other_arm", "dns", "network", "package_install", "git", "socket", "credential"]}
    },
    "contract_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
