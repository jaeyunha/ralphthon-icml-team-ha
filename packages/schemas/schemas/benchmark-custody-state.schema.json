{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/benchmark-custody-state.schema.json",
  "title": "BenchmarkCustodyState",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "campaign_id", "state", "history", "prerequisites", "quarantine_reason", "reveal_count", "state_hash"],
  "properties": {
    "version": {"const": 1},
    "campaign_id": {"type": "string", "minLength": 1},
    "state": {"enum": ["planned", "provenance_locked", "profiles_locked", "running", "arms_terminal", "generated_annotations_frozen", "reveal_ready", "revealed", "scored", "quarantined"]},
    "history": {"type": "array", "minItems": 1, "items": {"enum": ["planned", "provenance_locked", "profiles_locked", "running", "arms_terminal", "generated_annotations_frozen", "reveal_ready", "revealed", "scored", "quarantined"]}},
    "prerequisites": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["campaign_manifest_hash", "arm_freeze_hashes", "gold_annotations_hash", "generated_annotations_hash", "adjudication_hash", "reliability_hash", "usage_reconciliation_hash", "job_reconciliation_hash", "scorer_hash", "prerequisite_hash"],
          "properties": {
            "campaign_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "arm_freeze_hashes": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}},
            "gold_annotations_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "generated_annotations_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "adjudication_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "reliability_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "usage_reconciliation_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "job_reconciliation_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "scorer_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "prerequisite_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
          }
        }
      ]
    },
    "quarantine_reason": {"type": ["string", "null"]},
    "reveal_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "state_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
