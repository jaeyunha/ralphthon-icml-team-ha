{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/semantic-coverage-ledger.schema.json",
  "title": "SemanticCoverageLedger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "frozen_input_hash", "extraction_anchor_catalog_hash", "dossier_hash", "inventory", "units", "ledger_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "frozen_input_hash": {"$ref": "#/$defs/sha256"},
    "extraction_anchor_catalog_hash": {"$ref": "#/$defs/sha256"},
    "dossier_hash": {"$ref": "#/$defs/sha256"},
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_count", "section_ids", "supplements"],
      "properties": {
        "page_count": {"type": "integer", "minimum": 1},
        "section_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^SEC-[0-9]{4}$"}},
        "supplements": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["supplement_id", "content_hash"],
            "properties": {
              "supplement_id": {"type": "string", "pattern": "^SUP-[A-Za-z0-9._-]+$"},
              "content_hash": {"$ref": "#/$defs/sha256"}
            }
          }
        }
      }
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/unit"}
    },
    "ledger_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonEmptyStringArray": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "validatorAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "assignment_id", "evidence_refs"],
      "properties": {
        "lane": {"enum": ["mathematics", "statistics", "code", "references", "ethics", "arbitration"]},
        "assignment_id": {"type": "string", "minLength": 1},
        "evidence_refs": {"$ref": "#/$defs/nonEmptyStringArray"}
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "kind", "source_ref", "extraction_anchor_ids", "dossier_claim_ids", "applicable_validator_lanes", "validator_assignments", "evidence_refs", "terminal_disposition", "disposition_reason", "legacy_unverifiable", "unit_hash"],
      "properties": {
        "unit_id": {"type": "string", "pattern": "^(?:page:[1-9][0-9]*|section:SEC-[0-9]{4}|supplement:SUP-[A-Za-z0-9._-]+)$"},
        "kind": {"enum": ["page", "section", "supplement"]},
        "source_ref": {"type": "string", "minLength": 1},
        "extraction_anchor_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^(?:SEC|FIG|TAB|EQ|THM|CIT|TXT)-[0-9]{4}$"}},
        "dossier_claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "applicable_validator_lanes": {"type": "array", "uniqueItems": true, "items": {"enum": ["mathematics", "statistics", "code", "references", "ethics", "arbitration"]}},
        "validator_assignments": {"type": "array", "items": {"$ref": "#/$defs/validatorAssignment"}},
        "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "terminal_disposition": {"enum": ["covered", "unsupported_justified", "unverified_justified"]},
        "disposition_reason": {"type": ["string", "null"]},
        "legacy_unverifiable": {"const": false},
        "unit_hash": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
