{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/watchdog-config.schema.json",
  "title": "WatchdogConfig",
  "description": "Watchdog execution plan, phase gates, runner paths, subscriptions, publication targets, and safety policy.",
  "type": "object",
  "additionalProperties": false,
  "required": ["phase_runs"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "initial_state": {"type": "string", "minLength": 1},
    "initial_run_state": {"type": "string", "minLength": 1},
    "run_state": {"type": "string", "minLength": 1},
    "runner": {"type": "string", "minLength": 1},
    "poll_seconds": {"type": "number", "exclusiveMinimum": 0},
    "initial_backoff_seconds": {"type": "number", "minimum": 0},
    "max_backoff_seconds": {"type": "number", "minimum": 0},
    "auto_advance_run_state": {"type": "boolean"},
    "advance_empty_states": {"type": "boolean"},
    "complete_when_all_phases": {"type": "boolean"},
    "facts": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_wall_clock_seconds": {"type": "number", "minimum": 0},
        "max_wall_clock_hours": {"type": "number", "minimum": 0},
        "max_budget_usd": {"type": "number", "minimum": 0},
        "max_restarts_per_role": {"type": "integer", "minimum": 0},
        "max_reviewer_restarts": {"type": "integer", "minimum": 0},
        "max_validator_restarts": {"type": "integer", "minimum": 0},
        "max_author_restarts": {"type": "integer", "minimum": 0},
        "max_ac_restarts": {"type": "integer", "minimum": 0},
        "max_restarts": {"type": "integer", "minimum": 0},
        "max_discussion_rounds": {"type": "integer", "minimum": 0},
        "no_progress_threshold": {"type": "integer", "minimum": 1}
      }
    },
    "run_state_gates": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": {"enum": ["file_exists", "json_equals", "event_seen"]},
                "path": {"type": "string", "minLength": 1},
                "field": {"type": "string", "minLength": 1},
                "value": true,
                "pattern": {"type": "string", "minLength": 1}
              }
            }
          ]
        }
      }
    },
    "phase_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent_id", "role", "phase"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "role_instance_id": {"type": "string", "minLength": 1},
          "role": {"enum": ["reviewer", "author", "ac", "sac", "pc", "validator", "extractor", "watchdog"]},
          "phase": {"type": "string", "minLength": 1},
          "run_states": {
            "type": "array",
            "items": {"enum": ["CREATED", "INGESTING", "DOSSIER", "PERSONA_ASSIGNMENT", "PRELIMINARY_REVIEW", "VALIDATION", "OFFICIAL_REVIEW", "AUTHOR_REBUTTAL", "REVIEWER_FOLLOWUP", "AUTHOR_FINAL", "INTERNAL_DISCUSSION", "AC_META_REVIEW", "SAC_CALIBRATION", "PC_FINALIZATION", "COMPLETE"]},
            "uniqueItems": true
          },
          "gates": {
            "type": "array",
            "items": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type"],
                  "properties": {
                    "type": {"enum": ["file_exists", "json_equals", "event_seen"]},
                    "path": {"type": "string", "minLength": 1},
                    "field": {"type": "string", "minLength": 1},
                    "value": true,
                    "pattern": {"type": "string", "minLength": 1}
                  }
                }
              ]
            }
          },
          "completion_gates": {
            "type": "array",
            "items": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type"],
                  "properties": {
                    "type": {"enum": ["file_exists", "json_equals", "event_seen"]},
                    "path": {"type": "string", "minLength": 1},
                    "field": {"type": "string", "minLength": 1},
                    "value": true,
                    "pattern": {"type": "string", "minLength": 1}
                  }
                }
              ]
            }
          },
          "subscriptions": {
            "type": "array",
            "items": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "minProperties": 1,
                  "properties": {
                    "event": {"type": "string", "minLength": 1},
                    "path": {"type": "string", "minLength": 1}
                  }
                }
              ]
            }
          },
          "requires_artifact": {"type": "boolean"},
          "artifacts_are_validated": {"type": "boolean"},
          "runner_interface": {"type": "string", "minLength": 1},
          "tasks_template": {"type": "string", "minLength": 1},
          "task_context": {"type": "string", "minLength": 1},
          "current_task_context": {"$ref": "task-context.schema.json"},
          "output_schema": {"type": "string", "minLength": 1},
          "schema": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "policy": {"type": "string", "minLength": 1},
          "rubric": {"type": "string", "minLength": 1},
          "role_prompt": {"type": "string", "minLength": 1},
          "phase_prompt": {"type": "string", "minLength": 1},
          "persona": {"$ref": "persona.schema.json"},
          "manifest_generator": {"type": "string", "minLength": 1},
          "artifact_validator": {"type": "string", "minLength": 1},
          "ledgers": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "allow": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "timeout_seconds": {"type": "integer", "minimum": 1},
          "agent_command": {"type": "string", "minLength": 1},
          "agent_args": {"type": "array", "items": {"type": "string"}},
          "use_contract_manifest": {"type": "boolean"},
          "score_history": {"$ref": "score-history.schema.json"},
          "literature_registry": {"$ref": "literature-registry.schema.json"},
          "response_matrix": {"$ref": "response-matrix.schema.json"},
          "publication_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "publish_path": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
