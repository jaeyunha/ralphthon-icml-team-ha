{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/event-semantic-draft-v2.schema.json",
  "title": "EventSemanticDraftV2",
  "description": "Persisted v2 event semantics. Chronology is assigned only by the canonical append authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "idempotency_key", "run_id", "occurred_at", "type", "actor", "payload"],
  "properties": {
    "schema_version": {"const": 2},
    "event_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "idempotency_key": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "role", "phase"],
      "properties": {
        "agent_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
        "role": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
        "phase": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"}
      }
    },
    "payload": {"type": "object"},
    "artifact_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "causation_event_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"}
  }
}
