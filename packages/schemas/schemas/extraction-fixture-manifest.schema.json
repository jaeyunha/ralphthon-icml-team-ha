{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/extraction-fixture-manifest.schema.json",
  "title": "ExtractionFixtureManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "paper_id", "state", "tool", "source", "artifacts", "assets", "verification", "dossier_summary", "verified_bundle_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "minLength": 1},
    "paper_id": {"type": "string", "minLength": 1},
    "state": {"enum": ["candidate", "golden"]},
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "docling"},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pdf_committed", "pdf_filename", "pdf_sha256", "size_bytes"],
      "properties": {
        "pdf_committed": {"type": "boolean"},
        "pdf_filename": {"type": "string", "pattern": "^[^/]+\\.pdf$"},
        "pdf_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?:[A-Za-z0-9][A-Za-z0-9._-]*/)*[A-Za-z0-9][A-Za-z0-9._-]*$"},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "total_size_bytes", "tree_sha256"],
      "properties": {
        "file_count": {"type": "integer", "minimum": 0},
        "total_size_bytes": {"type": "integer", "minimum": 0},
        "tree_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_size", "status", "unresolved_anchor_count"],
      "properties": {
        "sample_size": {"type": "integer", "minimum": 0},
        "status": {"enum": ["passed", "failed"]},
        "unresolved_anchor_count": {"type": "integer", "minimum": 0}
      }
    },
    "dossier_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assumptions", "equations", "experiments", "claims", "references", "theorems"],
      "properties": {
        "assumptions": {"type": "integer", "minimum": 0},
        "equations": {"type": "integer", "minimum": 0},
        "experiments": {"type": "integer", "minimum": 0},
        "claims": {"type": "integer", "minimum": 0},
        "references": {"type": "integer", "minimum": 0},
        "theorems": {"type": "integer", "minimum": 0}
      }
    },
    "verified_bundle_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
