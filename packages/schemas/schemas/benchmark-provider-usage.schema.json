{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/benchmark-provider-usage.schema.json",
  "title": "BenchmarkProviderUsage",
  "type": "object",
  "additionalProperties": false,
  "required": ["invocation_id", "provider", "assignment", "input_tokens", "output_tokens", "cached_input_tokens", "billed_usd", "provider_record_hash", "runtime_settings_hash", "record_hash"],
  "properties": {
    "invocation_id": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "assignment": {"type": "string", "pattern": "^(paper:[^:]+:[^:]+:[^:]+|arm:[^:]+:reserve)$"},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "cached_input_tokens": {"type": "integer", "minimum": 0},
    "billed_usd": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$"},
    "provider_record_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "runtime_settings_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "record_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
