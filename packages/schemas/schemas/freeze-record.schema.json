{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/freeze-record.schema.json",
  "title": "FreezeRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "frozen_at", "review_start_time", "literature_cutoff", "extraction_tool", "run_config_hash", "repository_commit", "inputs", "freeze_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "frozen_at": {"type": "string", "format": "date-time"},
    "review_start_time": {"type": "string", "format": "date-time"},
    "literature_cutoff": {"type": "string", "minLength": 1},
    "extraction_tool": {"type": "object", "additionalProperties": false, "required": ["name", "version"], "properties": {"name": {"type": "string"}, "version": {"type": "string"}}},
    "run_config_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "repository_commit": {"type": ["string", "null"]},
    "inputs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "size_bytes": {"type": "integer", "minimum": 0}}}},
    "freeze_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
