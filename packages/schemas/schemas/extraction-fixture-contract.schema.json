{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/extraction-fixture-contract.schema.json",
  "title": "ExtractionFixtureContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixture_id", "paper_id", "state", "generated_artifacts_present", "source", "expected_artifacts", "required_invariants", "promotion_requirements"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "minLength": 1},
    "paper_id": {"type": "string", "minLength": 1},
    "state": {"enum": ["candidate", "golden"]},
    "generated_artifacts_present": {"type": "boolean"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pdf_committed", "pdf_available_in_checkout", "sha256", "note"],
      "properties": {
        "pdf_committed": {"type": "boolean"},
        "pdf_available_in_checkout": {"type": "boolean"},
        "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "required_for_golden", "present"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?:[A-Za-z0-9][A-Za-z0-9._-]*/)*[A-Za-z0-9][A-Za-z0-9._-]*/?$"},
          "kind": {"type": "string", "minLength": 1},
          "required_for_golden": {"type": "boolean"},
          "present": {"type": "boolean"}
        }
      }
    },
    "required_invariants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "promotion_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["real_production_run", "manual_placeholder_content_forbidden", "all_expected_artifacts_present", "all_required_invariants_validated", "state_after_promotion"],
      "properties": {
        "real_production_run": {"type": "boolean"},
        "manual_placeholder_content_forbidden": {"type": "boolean"},
        "all_expected_artifacts_present": {"type": "boolean"},
        "all_required_invariants_validated": {"type": "boolean"},
        "state_after_promotion": {"const": "golden"}
      }
    }
  }
}
