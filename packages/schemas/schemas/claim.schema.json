{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "type", "statement", "anchor", "supporting_items", "dependencies", "scope", "centrality"],
  "properties": {
    "claim_id": {"type": "string", "minLength": 1},
    "type": {"enum": ["theoretical", "empirical_result", "empirical_generalization", "methodological", "complexity", "reproducibility", "novelty", "other"]},
    "statement": {"type": "string", "minLength": 1},
    "anchor": {"type": "string", "minLength": 1},
    "supporting_items": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "scope": {"enum": ["narrow", "moderate", "broad"]},
    "centrality": {"enum": ["minor", "major", "central"]}
  }
}
