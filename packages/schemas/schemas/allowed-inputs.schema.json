{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/allowed-inputs.schema.json",
  "title": "AllowedInputs",
  "description": "Phase-specific mount manifest. manifest_hash is SHA-256 over the canonical document with manifest_hash omitted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "agent_id", "role", "phase", "permissions", "inputs", "manifest_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "agent_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "role": {"enum": ["reviewer", "author", "ac", "sac", "pc", "validator_code", "validator_mathematics", "validator_statistics", "validator_references", "validator_ethics", "validator_arbitration"]},
    "phase": {"type": "string", "minLength": 1},
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["own_private_state", "paper", "validation", "other_reviews", "author_response", "internal_discussion"],
      "properties": {
        "own_private_state": {"const": "yes"},
        "paper": {"enum": ["yes", "as-needed"]},
        "validation": {"enum": ["published-bundle-only", "yes", "author-visible"]},
        "other_reviews": {"enum": ["no", "no-by-default", "yes", "all-official-reviews", "followups"]},
        "author_response": {"enum": ["no", "own-thread", "yes", "not-applicable", "prior-responses", "published"]},
        "internal_discussion": {"enum": ["no", "ac-issues", "yes", "no-private-prep", "full", "full-record", "final-record"]}
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "category", "visibility"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "not": {"anyOf": [{"pattern": "^/"}, {"pattern": "(^|/)\\.\\.(/|$)"}]}},
          "category": {"enum": ["own_private_state", "paper", "validation", "other_reviews", "author_response", "internal_discussion", "policy", "rubric", "role_prompt", "phase_prompt", "persona", "task_context", "schema"]},
          "visibility": {"enum": ["full", "published_only", "own_thread", "author_visible", "followups", "prior_responses", "ac_issues", "final_record", "as_needed"]}
        }
      }
    },
    "manifest_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
