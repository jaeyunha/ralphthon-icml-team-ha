{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/paper-dossier.schema.json",
  "title": "PaperDossier",
  "type": "object",
  "additionalProperties": false,
  "required": ["dossier_version", "submission_id", "contributions", "claims", "method_graph", "equations", "theorems", "experiments", "datasets", "baselines", "metrics", "reported_results", "reproducibility", "references", "limitations", "ethical_risk_triggers", "ambiguities"],
  "properties": {
    "dossier_version": {"const": 1},
    "submission_id": {"type": "string", "minLength": 1},
    "contributions": {"type": "array", "items": {"type": "object"}},
    "claims": {"type": "array", "items": {"type": "object"}},
    "method_graph": {"type": "array", "items": {"type": "object"}},
    "equations": {"type": "array", "items": {"type": "object"}},
    "theorems": {"type": "array", "items": {"type": "object"}},
    "experiments": {"type": "array", "items": {"type": "object"}},
    "datasets": {"type": "array", "items": {"type": "object"}},
    "baselines": {"type": "array", "items": {"type": "object"}},
    "metrics": {"type": "array", "items": {"type": "object"}},
    "reported_results": {"type": "array", "items": {"type": "object"}},
    "reproducibility": {"type": "array", "items": {"type": "object"}},
    "references": {"type": "array", "items": {"type": "object"}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "ethical_risk_triggers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "ambiguities": {"type": "array", "items": {"type": "string"}}
  }
}
