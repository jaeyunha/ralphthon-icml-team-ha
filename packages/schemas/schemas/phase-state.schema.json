{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/schemas/phase-state.schema.json",
  "title": "PhaseState",
  "description": "One execution row for a persistent agent identity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["phase", "status", "current_task", "attempt", "last_artifact_hash", "no_progress_count"],
  "properties": {
    "phase_run_id": {"type": "string", "minLength": 1},
    "agent_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["reviewer", "author", "ac", "sac", "pc", "validator", "extractor", "watchdog"]},
    "phase": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending", "running", "blocked", "completed", "failed", "stalled"]},
    "current_task": {"type": ["string", "null"]},
    "attempt": {"type": "integer", "minimum": 0},
    "attempt_count": {"type": "integer", "minimum": 0},
    "allowed_input_manifest_hash": {"type": "string", "pattern": "^sha256:(?:[a-f0-9]{64}|\\.\\.\\.)$"},
    "input_manifest_hash": {"type": "string", "pattern": "^sha256:(?:[a-f0-9]{64}|\\.\\.\\.)$"},
    "last_artifact_hash": {"type": ["string", "null"], "pattern": "^sha256:(?:[a-f0-9]{64}|\\.\\.\\.)$"},
    "no_progress_count": {"type": "integer", "minimum": 0},
    "reason": {"type": ["string", "null"]},
    "failure_category": {"type": ["string", "null"]},
    "reopen_category": {"type": ["string", "null"]},
    "reopen_reason": {"type": ["string", "null"]},
    "last_promise": {"type": ["string", "null"], "enum": ["NEXT", "COMPLETE", "BLOCKED", null]},
    "pid": {"type": ["integer", "null"], "minimum": 1},
    "next_eligible_at": {"type": ["string", "null"], "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "heartbeat_at": {"type": "string", "format": "date-time"},
    "last_artifact_id": {"type": ["string", "null"]},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
