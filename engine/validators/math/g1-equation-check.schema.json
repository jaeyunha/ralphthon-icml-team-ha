{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-review.dev/internal/g1-equation-check.schema.json",
  "title": "G1EquationCheckInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_ref", "variables", "paper_expression", "implementation_expression", "sample_domains"],
  "properties": {
    "artifact_ref": {"type": "string", "minLength": 1},
    "variables": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
    "paper_expression": {"type": "string", "minLength": 1},
    "implementation_expression": {"type": "string", "minLength": 1},
    "sample_domains": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["min", "max"],
        "properties": {
          "min": {"type": "number"},
          "max": {"type": "number"},
          "points": {"type": "integer", "minimum": 2}
        }
      }
    },
    "tolerance": {"type": "number", "minimum": 0}
  }
}
